# ══════════════════════════════════════════════════════════════════
# .gitignore — Egakat SPA / ClaudeWork
# Regla general: código sube, datos NO suben
# ══════════════════════════════════════════════════════════════════

# ── Instrucciones Claude Code — info interna, no subir ───────────
CLAUDE.md

# ── Capturas de pantalla ─────────────────────────────────────────
*.png
*.jpg
*.jpeg

# ── Credenciales — NUNCA subir ────────────────────────────────────
.env
*.env
*.key
*.pem
*.cert
*.pfx
*.p12
.env.local
.env.*.local


# ── Datos de empresa — NUNCA subir ───────────────────────────────
*.xlsx
# Excepción: plantilla patrón para clientes (no contiene datos reales)
!chiquito_financiero/Plantilla_ChiquitoFinanzas.xlsx
*.xls
*.csv
*.pdf
Solicitudes_IT/
AI_Agent/powerbi_output/
otros_proyectos/

# ── Documentos corporativos ───────────────────────────────────────
Documentos/
NPS_Encuesta/*.docx
NPS_Encuesta/*.pptx

# ── Excepción: documentación técnica AI_Agent SÍ sube ────────────
!AI_Agent/Guia_AI_Agent_Egakat.docx
!AI_Agent/generar_guia_agente.py

# ── Backups generados por generador.py ───────────────────────────
_*_backup_*.py
*backup*.py
*Backup*.py

# ── Estado interno ────────────────────────────────────────────────
VDR_Comparador/vdr_ultimo_procesado.txt
crypto_bot/data/
crypto_bot/estado_grid*.json

# ── Python ───────────────────────────────────────────────────────
__pycache__/
*.pyc
*.pyc.*
*.pyo
*.pyd
.venv/
ai-agent-env/

# ── Logs ─────────────────────────────────────────────────────────
logs/
*.log

# ── Debug e instaladores ──────────────────────────────────────────
_debug_historico/
_instaladores/

# ── Temporales ───────────────────────────────────────────────────
*.tmp
*.bak
~$*
tmp_*.json
test_*.py
# Archivos chunk de procesamiento
*_chunk_*.xlsx
*_chunk_*.xls
# Archivos con path corrupto (Windows)
C:ClaudeWork*
# Downloads temporales
Productividad_Automatizacion/logs/downloads/
# Logs de limpieza
logs/cleanup/

# ── Administración — scripts de permisos (no subir a GitHub) ──────
_admin/

# ── VS Code ───────────────────────────────────────────────────────
.vscode/settings.json

# IDE
.vscode/
.idea/

# ── Claude Code ───────────────────────────────────────────────────
.claude/settings.local.json
.claude/worktrees/

# Python build
dist/
build/
*.egg-info/

# Mac / Windows basura
.DS_Store
Thumbs.db
venv/

# Browser profiles / Playwright artifacts
**/.footystats_profile/
**/Cache/
**/Cache_Data/
**/Local Storage/
**/Session Storage/
**/IndexedDB/
**/Cookies
**/Network/
**/GPUCache/
