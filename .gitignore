# ══════════════════════════════════════════════════════════════════
# .gitignore — Egakat SPA / ClaudeWork
# Regla general: código sube, datos NO suben
# ══════════════════════════════════════════════════════════════════

# ── Credenciales — NUNCA subir ────────────────────────────────────
.env
*.env
*.key
*.pem
*.cert
*.pfx
*.p12
.env.local
.env.*.local


# ── Datos de empresa — NUNCA subir ───────────────────────────────
*.xlsx
*.xls
*.csv
*.pdf
Solicitudes_IT/
AI_Agent/powerbi_output/
otros_proyectos/

# ── Documentos corporativos ───────────────────────────────────────
Documentos/
NPS_Encuesta/*.docx
NPS_Encuesta/*.pptx

# ── Excepción: documentación técnica AI_Agent SÍ sube ────────────
!AI_Agent/Guia_AI_Agent_Egakat.docx
!AI_Agent/generar_guia_agente.py

# ── Backups generados por generador.py ───────────────────────────
_*_backup_*.py

# ── Estado interno ────────────────────────────────────────────────
VDR_Comparador/vdr_ultimo_procesado.txt

# ── Python ───────────────────────────────────────────────────────
__pycache__/
*.pyc
*.pyo
*.pyd
.venv/
ai-agent-env/

# ── Logs ─────────────────────────────────────────────────────────
logs/
*.log

# ── Debug e instaladores ──────────────────────────────────────────
_debug_historico/
_instaladores/

# ── Temporales ───────────────────────────────────────────────────
*.tmp
*.bak
~$*

# ── Administración — scripts de permisos (no subir a GitHub) ──────
_admin/

# ── VS Code ───────────────────────────────────────────────────────
.vscode/settings.json

# IDE
.vscode/
.idea/

# Python build
dist/
build/
*.egg-info/

# Mac / Windows basura
.DS_Store
Thumbs.db
venv/
