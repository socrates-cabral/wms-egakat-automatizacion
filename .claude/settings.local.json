{
  "permissions": {
    "allow": [
      "Bash(py:*)",
      "Bash(git add:*)",
      "Bash(git commit:*)",
      "Bash(git push:*)",
      "Bash(git status:*)",
      "Bash(git log:*)",
      "Bash(git diff:*)",
      "Bash(powershell -Command \"Set-ExecutionPolicy*\")",
      "Bash(powershell -Command \"[Environment]::SetEnvironmentVariable*\")",
      "Bash(powershell -Command \"Get-ScheduledTask*\")",
      "Bash(schtasks*)"
    ],
    "deny": [
      "Bash(rm -rf:*)",
      "Bash(del /f:*)",
      "Bash(format:*)"
    ]
  }
}
