# .claudeignore — archivos que Claude Code NUNCA debe leer
# Similar a .gitignore

# Credenciales y secretos
.env
*.env
*.key
*.pem
*.cert
*.pfx
*.p12

# Solicitudes IT (pueden contener datos corporativos sensibles)
Solicitudes_IT/

# Logs (pueden contener datos sensibles)
logs/
*.log

# Debug historico
_debug_historico/

# Instaladores
_instaladores/

# Archivos de estado interno
VDR_Comparador/vdr_ultimo_procesado.txt

# Cache y temporales
__pycache__/
*.pyc
*.pyo
.venv/
ai-agent-env/
